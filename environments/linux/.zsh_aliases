# Modern Unix
alias ls='eza -lah'
alias lss='ls --total-size --ignore-glob node_modules'
alias bat='bat --paging=never'
alias df='duf'
alias find='fd'
alias top='gtop'
alias htop='gtop'
alias ping='gping'
alias ps='procs'
alias dig='q'
alias xargs='gxargs'
alias cz='chezmoi'
# Git
alias gpu='git pull --rebase --autostash'
alias gpf='git push --force-with-lease'
alias gsm='git stash > /dev/null && (git switch -q master 2> /dev/null || git switch -q main)'
alias gsmp='gsm && gpu'
alias gpr='git removed-branches --prune --force'
alias gsc='git stash clear && echo "All stashes cleared"'
alias gcl='gpr && gsc'
# Shortcuts
alias zshrc='nano ~/.local/share/chezmoi/environments/linux/.zshrc && cz apply && source ~/.zshrc'
alias aliases='nano ~/.local/share/chezmoi/environments/linux/.zsh_aliases && cz apply && source ~/.zshrc'
alias bu='brew update --verbose && brew outdated'
alias bg='brew upgrade'
alias local-gitignore='git local-ignore'
alias brew='~/.maintenance/brew-sbom.sh'
alias apt='sudo apt'
